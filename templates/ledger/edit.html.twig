{% extends 'base.html.twig' %}

{% set page_title = 'Edit entry' %}
{% set page_header = true %}

{% block body %}
<div class="py-8 max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('ledger_index') }}"
            class="text-muted-foreground hover:text-foreground transition-colors">
            <twig:ux:icon name="material-symbols:arrow-back" class="size-5" />
        </a>
        <div>
            <h1 class="font-heading font-bold text-3xl text-foreground">Edit entry</h1>
            <code class="font-mono text-sm text-primary">{{ entry.documentNumber }}</code>
        </div>
    </div>

    {% for message in app.flashes('error') %}
    <twig:Alert variant="destructive" class="mb-4">
        <twig:Alert:Description>{{ message }}</twig:Alert:Description>
    </twig:Alert>
    {% endfor %}

    {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

    <div class="grid grid-cols-2 gap-4">
        {{ form_row(form.subsidiary) }}
        {{ form_row(form.mainCategory) }}
    </div>
    <div class="grid grid-cols-2 gap-4">
        {{ form_row(form.docType) }}
        {{ form_row(form.subCategory) }}
    </div>
    {{ form_row(form.docNumber) }}
    {{ form_row(form.title) }}

    <div class="flex gap-3 pt-2">
        <button type="submit"
            class="inline-flex items-center gap-2 h-10 px-6 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 transition-colors">
            <twig:ux:icon name="material-symbols:save-outline" class="size-4" />
            Save changes
        </button>
        <a href="{{ path('ledger_index') }}"
            class="inline-flex items-center h-10 px-4 rounded-md border border-border text-sm hover:bg-muted transition-colors">
            Cancel
        </a>
    </div>

    {{ form_end(form) }}

    {# Delete section #}
    <div class="mt-10 pt-6 border-t border-border">
        <h2 class="text-sm font-medium text-destructive mb-3">Danger zone</h2>
        <form action="{{ path('ledger_delete', {id: entry.id}) }}" method="post"
            onsubmit="return confirm('Delete {{ entry.documentNumber }}? This cannot be undone.')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_entry_' ~ entry.id) }}">
            <button type="submit"
                class="inline-flex items-center gap-2 h-9 px-4 rounded-md bg-destructive/10 hover:bg-destructive/20 text-destructive text-sm font-medium transition-colors">
                <twig:ux:icon name="material-symbols:delete-outline" class="size-4" />
                Delete entry
            </button>
        </form>
    </div>
</div>
{% endblock %}
