{% extends 'base.html.twig' %}

{% set page_title = 'Edit entry' %}
{% set page_header = true %}

{% block body %}
<div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('ledger_index') }}"
            class="text-muted-foreground hover:text-foreground transition-colors">
            <twig:ux:icon name="material-symbols:arrow-back" class="size-5" />
        </a>
        <div>
            <h1 class="font-heading font-bold text-foreground text-3xl">Edit entry</h1>
            <code class="font-mono text-primary text-sm">{{ entry.documentId }}</code>
        </div>
    </div>

    {% for message in app.flashes('error') %}
    <twig:Alert variant="destructive" class="mb-4">
        <twig:Alert:Description>{{ message }}</twig:Alert:Description>
    </twig:Alert>
    {% endfor %}

    <twig:Card>
        <twig:Card:Content class="p-6">

        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        <div class="gap-4 grid grid-cols-2">
            {{ form_row(form.subsidiary) }}
            {{ form_row(form.mainCategory) }}
        </div>
        <div class="gap-4 grid grid-cols-2">
            {{ form_row(form.docType) }}
            {{ form_row(form.subCategory) }}
        </div>
        {{ form_row(form.docNumber) }}
        {{ form_row(form.title) }}
        {{ form_row(form.comments) }}

        <div class="flex gap-3 pt-2">
            <button type="submit"
                class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 px-6 rounded-md h-10 font-medium text-primary-foreground text-sm transition-colors">
                <twig:ux:icon name="material-symbols:save-outline" class="size-4" />
                Save changes
            </button>
            <a href="{{ path('ledger_index') }}"
                class="inline-flex items-center hover:bg-muted px-4 border border-border rounded-md h-10 text-sm transition-colors">
                Cancel
            </a>
        </div>

        {{ form_end(form) }}

        {# Delete section #}
        <div class="mt-10 pt-6 border-border border-t">
            <h2 class="mb-3 font-medium text-destructive text-sm">Danger zone</h2>
            <form action="{{ path('ledger_delete', {id: entry.id}) }}" method="post"
                onsubmit="return confirm('Delete {{ entry.documentId }}? This cannot be undone.')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_entry_' ~ entry.id) }}">
                <button type="submit"
                    class="inline-flex items-center gap-2 border border-destructive text-destructive hover:bg-destructive/10 px-4 rounded-md h-9 font-medium text-sm transition-colors">
                    <twig:ux:icon name="material-symbols:delete-outline" class="size-4" />
                    Delete entry
                </button>
            </form>
        </div>

        </twig:Card:Content>
    </twig:Card>
</div>
{% endblock %}
