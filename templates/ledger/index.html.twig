{% extends 'base.html.twig' %}

{% set page_title = 'Overview' %}
{% set page_header = true %}

{% block body %}
    <style>
        @media (min-width: 640px) {
            td[style*="display: none"] {
                display: table-cell !important;
            }
        }
    </style>
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="font-heading font-bold text-foreground text-3xl">Ledger</h1>
            <p class="mt-1 text-muted-foreground">All registered document numbers</p>
        </div>
    </div>

    {% for message in app.flashes('success') %}
    <twig:Alert class="bg-emerald-50 mb-4 border-emerald-200">
        <twig:ux:icon name="material-symbols:check-circle-outline" class="size-4 text-emerald-600" />
        <twig:Alert:Description class="text-emerald-800">{{ message }}</twig:Alert:Description>
    </twig:Alert>
    {% endfor %}

    <twig:LedgerTable />
</div>
{% endblock %}
