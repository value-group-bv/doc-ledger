<div {{ attributes }}>

{% if savedDocNumber %}
{# ── Success state ──────────────────────────────────────────────────────────── #}
<twig:Alert class="bg-emerald-50 mb-6 border-emerald-200">
    <twig:ux:icon name="material-symbols:check-circle-outline" class="size-4 text-emerald-600" />
    <twig:Alert:Title class="text-emerald-800">Entry registered</twig:Alert:Title>
    <twig:Alert:Description class="text-emerald-700">
        Document number <code class="font-mono font-semibold">{{ savedDocNumber }}</code> has been saved to the ledger.
    </twig:Alert:Description>
</twig:Alert>

<button type="button" data-action="live#action" data-live-action-param="resetConfirmation"
    class="inline-flex items-center gap-1.5 bg-primary hover:bg-primary/90 px-4 rounded-md h-9 font-medium text-primary-foreground text-sm transition-colors">
    <twig:ux:icon name="material-symbols:add" class="size-4" />
    Register another
</button>

{% else %}
{# ── Wizard form ─────────────────────────────────────────────────────────────── #}

<div class="gap-8 grid grid-cols-1 lg:grid-cols-3">

    {# Left: form fields #}
    <div class="space-y-5 lg:col-span-2">

        {# Row 1: Subsidiary + Main category #}
        <div class="gap-4 grid grid-cols-2">
            <div class="gap-2 grid">
                <label class="font-medium text-sm">Subsidiary</label>
                <select data-model="subsidiaryId" data-action="change->live#action"
                    class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 text-sm">
                    <option value="0">select</option>
                    {% for s in this.subsidiaries %}
                    <option value="{{ s.id }}" {% if subsidiaryId == s.id %}selected{% endif %}>{{ s.code }} - {{ s.description }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="gap-2 grid">
                <label class="font-medium text-sm">Main category</label>
                <select data-model="mainCategoryId" data-action="change->live#action"
                    class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 text-sm">
                    <option value="0">select</option>
                    {% for mc in this.mainCategories %}
                    <option value="{{ mc.id }}" {% if mainCategoryId == mc.id %}selected{% endif %}>{{ mc.code }} - {{ mc.description }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        {# Row 2: Doc type #}
        <div class="gap-2 grid">
            <label class="font-medium text-sm">Document type</label>
            <select data-model="docTypeId" data-action="change->live#action"
                class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 text-sm">
                <option value="0">select</option>
                {% for dt in this.docTypes %}
                <option value="{{ dt.id }}" {% if docTypeId == dt.id %}selected{% endif %}>{{ dt.code }} - {{ dt.description }}</option>
                {% endfor %}
            </select>
        </div>

        {# Row 4: Sub category — shown once doc type is selected #}
        {% if docTypeId %}
        <div class="gap-2 grid">
            <label class="font-medium text-sm">Sub category</label>
            <select data-model="subCategoryId" data-action="change->live#action"
                class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 text-sm">
                <option value="0">select</option>
                {% for sc in this.subCategories %}
                <option value="{{ sc.id }}" {% if subCategoryId == sc.id %}selected{% endif %}>{{ sc.formattedCode }} - {{ sc.description }}</option>
                {% endfor %}
            </select>
        </div>
        {% endif %}

        {# Row 5: Doc number — shown once sub category is selected #}
        {% if subCategoryId %}
        <div class="gap-2 grid">
            <label class="font-medium text-sm">Document number</label>

            <div class="flex gap-4 mb-2">
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="radio" data-model="docNumberMode" value="0"
                        data-action="change->live#action"
                        {% if docNumberMode == 0 %}checked{% endif %} />
                    Pre-defined
                </label>
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="radio" data-model="docNumberMode" value="1"
                        data-action="change->live#action"
                        {% if docNumberMode == 1 %}checked{% endif %} />
                    Manual (000–999)
                </label>
            </div>

            {% if docNumberMode == 0 %}
            {% set predefined = this.predefinedNumbers %}
            {% if predefined is not empty %}
            <select data-model="predefinedNumberId" data-action="change->live#action"
                class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 text-sm">
                <option value="0">Auto next available ({{ this.suggestedDocNumber|format_number({'fraction_digit': 0}) ~ '' }})</option>
                {% for pn in predefined %}
                <option value="{{ pn.id }}" {% if predefinedNumberId == pn.id %}selected{% endif %}>{{ pn.formattedCode }} - {{ pn.description }}</option>
                {% endfor %}
            </select>
            {% else %}
            <p class="text-muted-foreground text-sm">No pre-defined numbers for this sub category. Next available: <strong>{{ this.suggestedDocNumber }}</strong></p>
            {% endif %}
            {% else %}
            <input type="number" data-model="manualDocNumber"
                data-action="input->live#update:debounce(300ms)"
                value="{{ manualDocNumber }}"
                min="0" max="999" placeholder="{{ this.suggestedDocNumber }} (next available)"
                class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 font-mono text-sm" />
            {% endif %}
        </div>
        {% endif %}

        {# Row 6: Title #}
        <div class="gap-2 grid">
            <label class="font-medium text-sm">Title <span class="font-normal text-muted-foreground text-xs">(human-readable)</span></label>
            <input type="text" data-model="title"
                data-action="input->live#update:debounce(300ms)"
                value="{{ title }}"
                placeholder="e.g. System P&ID"
                class="flex bg-background px-3 py-2 border border-input rounded-md shadow-xs transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-10 text-sm" />
        </div>

        {# Row 7: Comments (optional) #}
        <div class="gap-2 grid">
            <label class="font-medium text-sm">Comments / search tags <span class="font-normal text-muted-foreground text-xs">(optional)</span></label>
            <twig:Textarea
                data-model="comments"
                data-action="input->live#update:debounce(300ms)"
                placeholder="Internal notes or keywords for improved searching"
                rows="3">{{ comments }}</twig:Textarea>
        </div>

        {# Submit #}
        <button type="button"
            data-action="live#action" data-live-action-param="save"
            {% if not subsidiaryId or not mainCategoryId or not docTypeId or not subCategoryId or not title %}
            disabled
            {% endif %}
            class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 disabled:opacity-50 mt-2 px-6 rounded-md h-10 font-medium text-primary-foreground text-sm transition-colors disabled:cursor-not-allowed">
            <twig:ux:icon name="material-symbols:save-outline" class="size-4" />
            Register document number
        </button>

    </div>

    {# Right: live preview #}
    <div>
        {% set previewDocNumber = this.previewDocNumber %}
        <twig:Card class="top-6 sticky">
            <twig:Card:Header>
                <twig:Card:Title>Live preview</twig:Card:Title>
                <twig:Card:Description>Updates as you fill in the form</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="bg-muted p-4 rounded-lg text-center">
                    <code class="font-mono text-sm font-semibold break-all {% if previewDocNumber != '—' %}text-primary{% else %}text-muted-foreground{% endif %}">
                        {{ previewDocNumber }}
                    </code>
                </div>
                {% if title %}
                <p class="mt-3 text-foreground text-sm">{{ title }}</p>
                {% endif %}
            </twig:Card:Content>
        </twig:Card>
    </div>

</div>

{% endif %}
</div>
