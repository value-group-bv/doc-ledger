{% set entries = this.entries %}
{% set totalPages = this.totalPages %}
{% set totalCount = this.totalCount %}

<div {{ attributes }}>

    {# ── Filter bar ─────────────────────────────────────────────────────────── #}
    <div class="flex flex-wrap gap-3 items-end mb-4">

        {# Search #}
        <div class="flex-1 min-w-[200px]">
            <label class="text-xs text-muted-foreground mb-1 block">Search</label>
            <input type="text"
                data-model="search"
                data-action="input->live#update:debounce(300ms)"
                value="{{ search }}"
                placeholder="Title or reference code…"
                class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
        </div>

        {# Subsidiary filter #}
        <div class="w-36">
            <label class="text-xs text-muted-foreground mb-1 block">Subsidiary</label>
            <select data-model="subsidiaryFilter" data-action="change->live#action" data-live-action-param="applyFilter"
                class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                <option value="0">All</option>
                {% for s in this.subsidiaries %}
                <option value="{{ s.id }}" {% if subsidiaryFilter == s.id %}selected{% endif %}>{{ s.code }}</option>
                {% endfor %}
            </select>
        </div>

        {# Doc type filter #}
        <div class="w-36">
            <label class="text-xs text-muted-foreground mb-1 block">Doc type</label>
            <select data-model="docTypeFilter" data-action="change->live#action" data-live-action-param="applyFilter"
                class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                <option value="0">All</option>
                {% for dt in this.docTypes %}
                <option value="{{ dt.id }}" {% if docTypeFilter == dt.id %}selected{% endif %}>{{ dt.code }}</option>
                {% endfor %}
            </select>
        </div>

        {# Main category filter #}
        <div class="w-44">
            <label class="text-xs text-muted-foreground mb-1 block">Main category</label>
            <select data-model="mainCategoryFilter" data-action="change->live#action" data-live-action-param="applyFilter"
                class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                <option value="0">All</option>
                {% for mc in this.mainCategories %}
                <option value="{{ mc.id }}" {% if mainCategoryFilter == mc.id %}selected{% endif %}>{{ mc.code }} — {{ mc.description }}</option>
                {% endfor %}
            </select>
        </div>

        {# Reset #}
        {% if search or subsidiaryFilter or docTypeFilter or mainCategoryFilter %}
        <button type="button" data-action="live#action" data-live-action-param="resetFilters"
            class="h-9 px-3 text-sm rounded-md border border-border hover:bg-muted text-muted-foreground transition-colors">
            Clear filters
        </button>
        {% endif %}

        {# Spacer + new entry button #}
        <div class="ml-auto">
            <a href="{{ path('ledger_new') }}"
                class="inline-flex items-center gap-1.5 h-9 px-4 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 transition-colors">
                <twig:ux:icon name="material-symbols:add" class="size-4" />
                New entry
            </a>
        </div>
    </div>

    {# ── Result count ────────────────────────────────────────────────────────── #}
    <p class="text-xs text-muted-foreground mb-3">
        {{ totalCount }} {{ totalCount == 1 ? 'entry' : 'entries' }}
        {% if search or subsidiaryFilter or docTypeFilter or mainCategoryFilter %} matching filters{% endif %}
    </p>

    {# ── Table ───────────────────────────────────────────────────────────────── #}
    <div class="rounded-lg border border-border overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-muted/50 border-b border-border">
                    <tr>
                        {% macro sort_th(label, field, currentField, currentDir) %}
                        <th class="text-left px-4 py-3 font-medium text-muted-foreground whitespace-nowrap">
                            <button type="button"
                                data-action="live#action"
                                data-live-action-param="sort"
                                data-live-field-param="{{ field }}"
                                class="flex items-center gap-1 hover:text-foreground transition-colors">
                                {{ label }}
                                {% if currentField == field %}
                                <twig:ux:icon name="{{ currentDir == 'ASC' ? 'material-symbols:arrow-upward' : 'material-symbols:arrow-downward' }}" class="size-3.5" />
                                {% else %}
                                <twig:ux:icon name="material-symbols:unfold-more" class="size-3.5 opacity-30" />
                                {% endif %}
                            </button>
                        </th>
                        {% endmacro %}

                        {{ _self.sort_th('Document number', 'e.referenceCode', sortField, sortDir) }}
                        {{ _self.sort_th('Title', 'e.title', sortField, sortDir) }}
                        {{ _self.sort_th('Subsidiary', 's.code', sortField, sortDir) }}
                        {{ _self.sort_th('Type', 'dt.code', sortField, sortDir) }}
                        {{ _self.sort_th('Main category', 'mc.code', sortField, sortDir) }}
                        {{ _self.sort_th('Sub category', 'sc.code', sortField, sortDir) }}
                        {{ _self.sort_th('No.', 'e.docNumber', sortField, sortDir) }}
                        <th class="px-4 py-3 text-right font-medium text-muted-foreground">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for entry in entries %}
                    <tr class="hover:bg-muted/30 transition-colors">
                        <td class="px-4 py-3">
                            <code class="font-mono text-xs border rounded px-2 py-0.5 whitespace-nowrap"
                                style="{{ subsidiary_doc_number_style(entry.subsidiary.code) }}">
                                {{ entry.documentNumberBase }}
                            </code>
                        </td>
                        <td class="px-4 py-3 font-medium text-foreground max-w-xs truncate">
                            {{ entry.title }}
                        </td>
                        <td class="px-4 py-3 text-muted-foreground text-xs">
                            {{ entry.subsidiary.code }}
                        </td>
                        <td class="px-4 py-3">
                            <twig:Badge style="{{ doc_type_badge_style(entry.docType.code) }}">{{ entry.docType.code }}</twig:Badge>
                        </td>
                        <td class="px-4 py-3 text-muted-foreground text-xs">
                            {{ entry.mainCategory.code }} — {{ entry.mainCategory.description }}
                        </td>
                        <td class="px-4 py-3 text-muted-foreground text-xs">
                            {{ entry.subCategory.formattedCode }} — {{ entry.subCategory.description }}
                        </td>
                        <td class="px-4 py-3 font-mono text-xs text-muted-foreground">
                            {{ '%03d'|format(entry.docNumber) }}
                        </td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex justify-end gap-1">
                                <a href="{{ path('ledger_edit', {id: entry.id}) }}"
                                    class="inline-flex items-center justify-center size-7 rounded hover:bg-muted text-muted-foreground hover:text-foreground transition-colors"
                                    title="Edit">
                                    <twig:ux:icon name="material-symbols:edit-outline" class="size-4" />
                                </a>
                                <button type="button"
                                    data-controller="confirm-delete"
                                    data-confirm-delete-url-value="{{ path('ledger_delete', {id: entry.id}) }}"
                                    class="inline-flex items-center justify-center size-7 rounded hover:bg-destructive/10 text-muted-foreground hover:text-destructive transition-colors"
                                    title="Delete">
                                    <twig:ux:icon name="material-symbols:delete-outline" class="size-4" />
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="px-4 py-12 text-center text-muted-foreground">
                            No entries found.
                            {% if search or subsidiaryFilter or docTypeFilter or mainCategoryFilter %}
                            <button type="button" data-action="live#action" data-live-action-param="resetFilters"
                                class="ml-2 text-primary hover:underline">Clear filters</button>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ── Pagination ──────────────────────────────────────────────────────────── #}
    {% if totalPages > 1 %}
    <div class="flex items-center justify-between mt-4">
        <p class="text-xs text-muted-foreground">
            Page {{ page }} of {{ totalPages }}
        </p>
        <div class="flex gap-1">
            <button type="button"
                data-action="live#action" data-live-action-param="goToPage"
                data-live-page-param="{{ max(page - 1, 1) }}"
                {% if page <= 1 %}disabled{% endif %}
                class="inline-flex items-center justify-center h-8 w-8 rounded border border-border hover:bg-muted disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                <twig:ux:icon name="material-symbols:chevron-left" class="size-4" />
            </button>

            {% for p in 1..totalPages %}
            {% if p == 1 or p == totalPages or (p >= page - 2 and p <= page + 2) %}
            <button type="button"
                data-action="live#action" data-live-action-param="goToPage"
                data-live-page-param="{{ p }}"
                class="inline-flex items-center justify-center h-8 min-w-8 px-2 rounded border text-sm transition-colors
                    {% if p == page %}bg-primary text-primary-foreground border-primary{% else %}border-border hover:bg-muted{% endif %}">
                {{ p }}
            </button>
            {% elseif p == page - 3 or p == page + 3 %}
            <span class="inline-flex items-center justify-center h-8 w-8 text-muted-foreground">…</span>
            {% endif %}
            {% endfor %}

            <button type="button"
                data-action="live#action" data-live-action-param="goToPage"
                data-live-page-param="{{ min(page + 1, totalPages) }}"
                {% if page >= totalPages %}disabled{% endif %}
                class="inline-flex items-center justify-center h-8 w-8 rounded border border-border hover:bg-muted disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                <twig:ux:icon name="material-symbols:chevron-right" class="size-4" />
            </button>
        </div>
    </div>
    {% endif %}

</div>
