{% set menus = [
    { title: 'Ledger', route: 'ledger_index' },
    { title: 'Admin', route: 'admin_index' }
] %}

<div class="mb-8 min-h-full" data-controller="header">
    <nav class="border-border border-b nav-gradient">
        <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
            <div class="flex justify-between items-center gap-6 h-[67px]">
                <!-- Logo -->
                <div class="flex items-center shrink-0">
                    <a href="{{ path('ledger_index') }}"
                        class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
                        <span class="font-heading font-bold text-white text-2xl">Value Group</span>
                        <span class="font-heading text-white/70 text-xl">Ledger</span>
                    </a>
                </div>

                <!-- Desktop Navigation -->
                <div class="hidden md:flex items-center gap-1">
                    {% for menu in menus %}
                    {% if menu.route != 'admin_index' or is_granted('ROLE_ADMIN') %}
                    {% set currentRoute = app.request.attributes.get('_route') %}
                    {% set isActive = currentRoute == menu.route or currentRoute starts with menu.route|split('_')[0] %}
                    <a href="{{ path(menu.route) }}"
                        class="px-3 py-2 text-sm font-medium rounded-md transition-colors {% if isActive %}text-primary-foreground bg-primary-foreground/20{% else %}text-primary-foreground/70 hover:text-primary-foreground hover:bg-primary-foreground/10{% endif %}"
                        aria-pressed="{{ isActive ? 'true' : 'false' }}">
                        {{ menu.title }}
                    </a>
                    {% endif %}
                    {% endfor %}
                </div>

                <!-- Right section -->
                <div class="flex items-center gap-2 md:gap-3 ml-auto">
                    <!-- Theme Selector -->
                    <div class="flex gap-1 bg-primary-foreground/10 backdrop-blur-sm p-1 rounded-lg"
                        data-controller="color-theme">
                        {% set themeBtn = 'p-1.5 rounded text-primary-foreground/60 hover:text-primary-foreground hover:bg-primary-foreground/20 aria-pressed:bg-primary-foreground/30 aria-pressed:text-primary-foreground transition-colors' %}
                        <button id="theme-system" type="button" aria-label="System Theme"
                            data-controller="toggle"
                            data-toggle-pressed-value="{{ app.request.cookies.get('theme') == 'system' or not app.request.cookies.has('theme') }}"
                            data-action="click->toggle#toggle click->color-theme#setSystem" class="{{ themeBtn }}"
                            title="System">
                            <twig:ux:icon name="material-symbols-light:computer-outline" />
                        </button>
                        <button id="theme-light" type="button" aria-label="Light Theme"
                            data-controller="toggle"
                            data-toggle-pressed-value="{{ app.request.cookies.get('theme') == 'light' }}"
                            data-action="click->toggle#toggle click->color-theme#setLight" class="{{ themeBtn }}"
                            title="Light">
                            <twig:ux:icon name="material-symbols-light:sunny-outline" />
                        </button>
                        <button id="theme-dark" type="button" aria-label="Dark Theme"
                            data-controller="toggle"
                            data-toggle-pressed-value="{{ app.request.cookies.get('theme') == 'dark' }}"
                            data-action="click->toggle#toggle click->color-theme#setDark" class="{{ themeBtn }}"
                            title="Dark">
                            <twig:ux:icon name="material-symbols-light:dark-mode-outline-rounded" />
                        </button>
                    </div>

                    <!-- User menu -->
                    <div class="group hidden md:block relative">
                        <button type="button"
                            class="flex items-center gap-2 hover:bg-primary-foreground/10 px-3 py-1.5 rounded-lg text-primary-foreground/70 hover:text-primary-foreground transition-colors"
                            aria-haspopup="true">
                            <span class="font-medium text-primary-foreground text-sm">
                                {{ app.user.displayName ?? app.user.email }}
                            </span>
                            <twig:ux:icon name="material-symbols-light:expand-more" class="size-4" />
                        </button>
                        <div class="invisible group-hover:visible right-0 z-50 absolute bg-card opacity-0 group-hover:opacity-100 shadow-lg mt-3 border border-border rounded-lg w-44 transition-all duration-150">
                            <a href="{{ path('app_logout') }}" data-turbo="false"
                                class="flex items-center gap-3 hover:bg-muted px-5 py-3 font-medium text-foreground text-sm transition-colors">
                                <twig:ux:icon name="uil:signout" class="size-4" />
                                <span>Sign out</span>
                            </a>
                        </div>
                    </div>

                    <!-- Mobile menu button -->
                    <button type="button" id="mobile-menu-btn"
                        class="md:hidden inline-flex justify-center items-center hover:bg-primary-foreground/10 p-2 rounded-md text-primary-foreground/70 hover:text-primary-foreground transition-colors"
                        aria-expanded="false" aria-controls="mobile-menu">
                        <span class="sr-only">Open main menu</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="aria-expanded:hidden block size-6">
                            <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-primary/20 border-border border-t">
            <div class="space-y-1 px-4 pt-2 pb-3">
                {% for menu in menus %}
                {% if menu.route != 'admin_index' or is_granted('ROLE_ADMIN') %}
                <a href="{{ path(menu.route) }}"
                    class="block hover:bg-primary-foreground/10 px-3 py-2 rounded-md font-medium text-primary-foreground/70 hover:text-primary-foreground text-base transition-colors">
                    {{ menu.title }}
                </a>
                {% endif %}
                {% endfor %}
            </div>
            <div class="space-y-2 px-4 py-3 border-border border-t">
                <a href="{{ path('app_logout') }}" data-turbo="false"
                    class="block hover:bg-primary-foreground/10 px-3 py-2 rounded-md font-medium text-primary-foreground/70 hover:text-primary-foreground text-base transition-colors">
                    Sign out
                </a>
            </div>
        </div>
    </nav>
</div>
