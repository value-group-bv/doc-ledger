{% extends 'base.html.twig' %}

{% set page_title = 'Admin' %}
{% set page_header = true %}

{% block body %}
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="font-heading font-bold text-foreground text-3xl">Admin</h1>
            <p class="mt-1 text-muted-foreground">Manage system settings and users</p>
        </div>
    </div>

    {% for message in app.flashes('success') %}
    <twig:Alert class="bg-emerald-50 mb-4 border-emerald-200">
        <twig:ux:icon name="material-symbols:check-circle-outline" class="size-4 text-emerald-600" />
        <twig:Alert:Description class="text-emerald-800">{{ message }}</twig:Alert:Description>
    </twig:Alert>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <twig:Alert class="bg-red-50 mb-4 border-red-200">
        <twig:ux:icon name="material-symbols:error-outline" class="size-4 text-red-600" />
        <twig:Alert:Description class="text-red-800">{{ message }}</twig:Alert:Description>
    </twig:Alert>
    {% endfor %}

    <div class="gap-8 grid grid-cols-1 xl:grid-cols-2">

        {# ── Subsidiaries ─────────────────────────────────────────────────────── #}
        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Subsidiaries</twig:Card:Title>
                <twig:Card:Description>Prefix codes for Value Group subsidiaries</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="overflow-x-auto">
                <table class="mb-4 w-full text-sm">
                    <thead><tr class="border-border border-b text-muted-foreground text-xs">
                        <th class="pb-2 text-left">Code</th>
                        <th class="pb-2 text-left">Description</th>
                        <th></th>
                    </tr></thead>
                    <tbody class="divide-y divide-border">
                    {% for s in subsidiaries %}
                    <tr>
                        <td class="py-2 font-mono font-semibold">{{ s.code }}</td>
                        <td class="py-2">{{ s.description }}</td>
                        <td class="py-2 text-right">
                            <form method="post" action="{{ path('admin_subsidiary_delete', {id: s.id}) }}"
                                onsubmit="return confirm('Delete {{ s.code }}?')">
                                <button type="submit" class="text-destructive text-xs hover:underline">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}<tr><td colspan="3" class="py-3 text-muted-foreground text-center">None yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
                </div>
                <form method="post" action="{{ path('admin_subsidiary_new') }}" class="flex flex-wrap gap-2">
                    <input name="code" placeholder="Code" maxlength="2"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-24 h-9 text-sm transition-[color,box-shadow]" />
                    <input name="description" placeholder="Description"
                        class="flex flex-1 bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]" />
                    <button type="submit" class="inline-flex items-center bg-primary hover:bg-primary/90 px-3 rounded-md h-9 text-primary-foreground text-sm transition-colors">Add</button>
                </form>
            </twig:Card:Content>
        </twig:Card>

        {# ── Main categories ──────────────────────────────────────────────────── #}
        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Main Categories</twig:Card:Title>
                <twig:Card:Description>Single-digit codes</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="overflow-x-auto">
                <table class="mb-4 w-full text-sm">
                    <thead><tr class="border-border border-b text-muted-foreground text-xs">
                        <th class="pb-2 text-left">Code</th>
                        <th class="pb-2 text-left">Ref.</th>
                        <th class="pb-2 text-left">Description</th>
                        <th></th>
                    </tr></thead>
                    <tbody class="divide-y divide-border">
                    {% for mc in mainCategories %}
                    <tr>
                        <td class="py-2 font-mono font-semibold">{{ mc.code }}</td>
                        <td class="py-2">
                            <form method="post" action="{{ path('admin_maincat_set_refcode', {id: mc.id}) }}">
                                <select name="referenceCode" onchange="this.form.submit()"
                                    class="bg-background shadow-xs px-2 border border-input focus-visible:border-ring rounded outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-7 font-mono text-xs transition-[color,box-shadow]">
                                    <option value="000" {% if mc.referenceCode == '000' %}selected{% endif %}>000</option>
                                    <option value="AAA" {% if mc.referenceCode == 'AAA' %}selected{% endif %}>AAA</option>
                                    <option value="PRO" {% if mc.referenceCode == 'PRO' %}selected{% endif %}>PRO</option>
                                </select>
                            </form>
                        </td>
                        <td class="py-2">{{ mc.description }}</td>
                        <td class="py-2 text-right">
                            <form method="post" action="{{ path('admin_maincat_delete', {id: mc.id}) }}"
                                onsubmit="return confirm('Delete {{ mc.code }}?')">
                                <button type="submit" class="text-destructive text-xs hover:underline">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}<tr><td colspan="4" class="py-3 text-muted-foreground text-center">None yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
                </div>
                <form method="post" action="{{ path('admin_maincat_new') }}" class="flex flex-wrap gap-2">
                    <input name="code" placeholder="Code" maxlength="1"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-20 h-9 text-sm transition-[color,box-shadow]" />
                    <select name="referenceCode"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 font-mono text-sm transition-[color,box-shadow]">
                        <option value="000">000</option>
                        <option value="AAA">AAA</option>
                        <option value="PRO">PRO</option>
                    </select>
                    <input name="description" placeholder="Description"
                        class="flex flex-1 bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]" />
                    <button type="submit" class="inline-flex items-center bg-primary hover:bg-primary/90 px-3 rounded-md h-9 text-primary-foreground text-sm transition-colors">Add</button>
                </form>
            </twig:Card:Content>
        </twig:Card>

        {# ── Doc types ────────────────────────────────────────────────────────── #}
        <twig:Card>
            <twig:Card:Header>
                <twig:Card:Title>Document Types</twig:Card:Title>
                <twig:Card:Description>Three-letter codes</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="overflow-x-auto">
                <table class="mb-4 w-full text-sm">
                    <thead><tr class="border-border border-b text-muted-foreground text-xs">
                        <th class="pb-2 text-left">Code</th>
                        <th class="pb-2 text-left">Description</th>
                        <th></th>
                    </tr></thead>
                    <tbody class="divide-y divide-border">
                    {% for dt in docTypes %}
                    <tr>
                        <td class="py-2"><twig:Badge style="{{ doc_type_badge_style(dt.code) }}">{{ dt.code }}</twig:Badge></td>
                        <td class="py-2">{{ dt.description }}</td>
                        <td class="py-2 text-right">
                            <form method="post" action="{{ path('admin_doctype_delete', {id: dt.id}) }}"
                                onsubmit="return confirm('Delete {{ dt.code }}?')">
                                <button type="submit" class="text-destructive text-xs hover:underline">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}<tr><td colspan="3" class="py-3 text-muted-foreground text-center">None yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
                </div>
                <form method="post" action="{{ path('admin_doctype_new') }}" class="flex flex-wrap gap-2">
                    <input name="code" placeholder="Code" maxlength="3"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-28 h-9 text-sm transition-[color,box-shadow]" />
                    <input name="description" placeholder="Description"
                        class="flex flex-1 bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]" />
                    <button type="submit" class="inline-flex items-center bg-primary hover:bg-primary/90 px-3 rounded-md h-9 text-primary-foreground text-sm transition-colors">Add</button>
                </form>
            </twig:Card:Content>
        </twig:Card>

        {# ── Sub categories ───────────────────────────────────────────────────── #}
        <twig:Card class="xl:col-span-2">
            <twig:Card:Header>
                <twig:Card:Title>Sub Categories</twig:Card:Title>
                <twig:Card:Description>Linked to a document type; three-digit codes</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="overflow-x-auto">
                <table class="mb-4 w-full text-sm">
                    <thead><tr class="border-border border-b text-muted-foreground text-xs">
                        <th class="pb-2 text-left">Subsidiary</th>
                        <th class="pb-2 text-left">Main cat.</th>
                        <th class="pb-2 text-left">Type</th>
                        <th class="pb-2 text-left">Code</th>
                        <th class="pb-2 text-left">Description</th>
                        <th></th>
                    </tr></thead>
                    <tbody class="divide-y divide-border">
                    {% for sc in subCategories %}
                    {% if sc.id == editSubcatId %}
                    <tr>
                        <form method="post" action="{{ path('admin_subcat_update', {id: sc.id}) }}" class="contents">
                        <td class="py-1">
                            <select name="subsidiaryId"
                                class="bg-background shadow-xs px-2 border border-input focus-visible:border-ring rounded outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-8 text-sm transition-[color,box-shadow]">
                                <option value="0">All</option>
                                {% for s in subsidiaries %}
                                <option value="{{ s.id }}" {% if sc.subsidiary and s.id == sc.subsidiary.id %}selected{% endif %}>{{ s.code }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="py-1">
                            <select name="mainCategoryId"
                                class="bg-background shadow-xs px-2 border border-input focus-visible:border-ring rounded outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-8 text-sm transition-[color,box-shadow]">
                                <option value="0">All</option>
                                {% for mc in mainCategories %}
                                <option value="{{ mc.id }}" {% if sc.mainCategory and mc.id == sc.mainCategory.id %}selected{% endif %}>{{ mc.code }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="py-1">
                            <select name="docTypeId"
                                class="bg-background shadow-xs px-2 border border-input focus-visible:border-ring rounded outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-8 text-sm transition-[color,box-shadow]">
                                {% for dt in docTypes %}
                                <option value="{{ dt.id }}" {% if dt.id == sc.docType.id %}selected{% endif %}>{{ dt.code }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="py-1">
                            <input name="code" type="number" min="0" max="999" value="{{ sc.code }}"
                                class="bg-background shadow-xs px-2 border border-input focus-visible:border-ring rounded outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-24 h-8 font-mono text-sm transition-[color,box-shadow]" />
                        </td>
                        <td class="py-1">
                            <input name="description" value="{{ sc.description }}"
                                class="bg-background shadow-xs px-2 border border-input focus-visible:border-ring rounded outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-full h-8 text-sm transition-[color,box-shadow]" />
                        </td>
                        <td class="py-1 text-right whitespace-nowrap">
                            <button type="submit" class="mr-3 text-primary text-xs hover:underline">Save</button>
                            <a href="{{ path('admin_index') }}" class="text-muted-foreground text-xs hover:underline">Cancel</a>
                        </td>
                        </form>
                    </tr>
                    {% else %}
                    <tr>
                        <td class="py-2 font-mono text-muted-foreground">{{ sc.subsidiary ? sc.subsidiary.code : 'All' }}</td>
                        <td class="py-2 font-mono text-muted-foreground">{{ sc.mainCategory ? sc.mainCategory.code : 'All' }}</td>
                        <td class="py-2"><twig:Badge style="{{ doc_type_badge_style(sc.docType.code) }}">{{ sc.docType.code }}</twig:Badge></td>
                        <td class="py-2 font-mono font-semibold">{{ sc.formattedCode }}</td>
                        <td class="py-2">{{ sc.description }}</td>
                        <td class="py-2 text-right whitespace-nowrap">
                            <a href="{{ path('admin_subcat_edit', {id: sc.id}) }}" class="mr-3 text-xs hover:underline">Edit</a>
                            <form method="post" action="{{ path('admin_subcat_delete', {id: sc.id}) }}"
                                onsubmit="return confirm('Delete {{ sc.formattedCode }}?')" class="inline">
                                <button type="submit" class="text-destructive text-xs hover:underline">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% endif %}
                    {% else %}<tr><td colspan="6" class="py-3 text-muted-foreground text-center">None yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
                </div>
                <form method="post" action="{{ path('admin_subcat_new') }}" class="flex flex-wrap gap-2">
                    <select name="subsidiaryId"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]">
                        <option value="0">All subsidiaries</option>
                        {% for s in subsidiaries %}
                        <option value="{{ s.id }}">{{ s.code }}</option>
                        {% endfor %}
                    </select>
                    <select name="mainCategoryId"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]">
                        <option value="0">All main cats.</option>
                        {% for mc in mainCategories %}
                        <option value="{{ mc.id }}">{{ mc.code }} - {{ mc.description }}</option>
                        {% endfor %}
                    </select>
                    <select name="docTypeId"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]">
                        <option value="">Doc type…</option>
                        {% for dt in docTypes %}
                        <option value="{{ dt.id }}">{{ dt.code }}</option>
                        {% endfor %}
                    </select>
                    <input name="code" type="number" min="0" max="999" placeholder="Code (0–999)"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-36 h-9 text-sm transition-[color,box-shadow]" />
                    <input name="description" placeholder="Description"
                        class="flex flex-1 bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 min-w-48 h-9 text-sm transition-[color,box-shadow]" />
                    <button type="submit" class="inline-flex items-center bg-primary hover:bg-primary/90 px-3 rounded-md h-9 text-primary-foreground text-sm transition-colors">Add</button>
                </form>
            </twig:Card:Content>
        </twig:Card>

        {# ── Predefined numbers ───────────────────────────────────────────────── #}
        <twig:Card class="xl:col-span-2">
            <twig:Card:Header>
                <twig:Card:Title>Predefined Document Numbers</twig:Card:Title>
                <twig:Card:Description>Fixed codes reserved for specific document types within a sub category</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="overflow-x-auto">
                <table class="mb-4 w-full text-sm">
                    <thead><tr class="border-border border-b text-muted-foreground text-xs">
                        <th class="pb-2 text-left">Type</th>
                        <th class="pb-2 text-left">Sub category</th>
                        <th class="pb-2 text-left">Code</th>
                        <th class="pb-2 text-left">Description</th>
                        <th></th>
                    </tr></thead>
                    <tbody class="divide-y divide-border">
                    {% for pn in predefinedNumbers %}
                    <tr>
                        <td class="py-2"><twig:Badge style="{{ doc_type_badge_style(pn.subCategory.docType.code) }}">{{ pn.subCategory.docType.code }}</twig:Badge></td>
                        <td class="py-2 font-mono text-muted-foreground">{{ pn.subCategory.formattedCode }}</td>
                        <td class="py-2 font-mono font-semibold">{{ pn.formattedCode }}</td>
                        <td class="py-2">{{ pn.description }}</td>
                        <td class="py-2 text-right">
                            <form method="post" action="{{ path('admin_predefined_delete', {id: pn.id}) }}"
                                onsubmit="return confirm('Delete {{ pn.formattedCode }}?')">
                                <button type="submit" class="text-destructive text-xs hover:underline">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}<tr><td colspan="5" class="py-3 text-muted-foreground text-center">None yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
                </div>
                <form method="post" action="{{ path('admin_predefined_new') }}" class="flex flex-wrap gap-2">
                    <select name="subCategoryId"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 h-9 text-sm transition-[color,box-shadow]">
                        <option value="">Sub category…</option>
                        {% for sc in subCategories %}
                        <option value="{{ sc.id }}">{{ sc.docType.code }} - {{ sc.formattedCode }} {{ sc.description }}</option>
                        {% endfor %}
                    </select>
                    <input name="code" type="number" min="0" max="999" placeholder="Code (0–999)"
                        class="flex bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 w-36 h-9 text-sm transition-[color,box-shadow]" />
                    <input name="description" placeholder="Description"
                        class="flex flex-1 bg-background shadow-xs px-3 py-2 border border-input focus-visible:border-ring rounded-md outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 min-w-48 h-9 text-sm transition-[color,box-shadow]" />
                    <button type="submit" class="inline-flex items-center bg-primary hover:bg-primary/90 px-3 rounded-md h-9 text-primary-foreground text-sm transition-colors">Add</button>
                </form>
            </twig:Card:Content>
        </twig:Card>

        {# ── Users ─────────────────────────────────────────────────────────────── #}
        <twig:Card class="xl:col-span-2">
            <twig:Card:Header>
                <twig:Card:Title>Users</twig:Card:Title>
                <twig:Card:Description>All users who have logged in via Microsoft 365</twig:Card:Description>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead><tr class="border-border border-b text-muted-foreground text-xs">
                        <th class="pb-2 text-left">Email</th>
                        <th class="pb-2 text-left">Roles</th>
                        <th class="pb-2 text-left">Joined</th>
                        <th></th>
                    </tr></thead>
                    <tbody class="divide-y divide-border">
                    {% for user in users %}
                    <tr>
                        <td class="py-2">{{ user.email }}</td>
                        <td class="py-2">
                            {% set extraRoles = user.roles|filter(r => r != 'ROLE_USER') %}
                            {% if extraRoles is empty %}
                            <twig:Badge variant="outline">User</twig:Badge>
                            {% else %}
                            {% for role in extraRoles %}
                            <twig:Badge variant="{{ role == 'ROLE_ADMIN' or role == 'ROLE_SUPERADMIN' ? 'default' : 'secondary' }}">{{ role|replace({'ROLE_': ''}) }}</twig:Badge>
                            {% endfor %}
                            {% endif %}
                        </td>
                        <td class="py-2 text-muted-foreground text-xs">{{ user.createdAt|date('d M Y') }}</td>
                        <td class="py-2 text-right">
                            {% if 'ROLE_SUPERADMIN' in user.roles %}
                            <span class="text-muted-foreground text-xs">Protected</span>
                            {% elseif user != app.user %}
                            <form method="post" action="{{ path('admin_user_toggle_admin', {id: user.id}) }}">
                                <button type="submit"
                                    class="text-xs {% if 'ROLE_ADMIN' in user.roles %}text-destructive{% else %}text-primary{% endif %} hover:underline">
                                    {{ 'ROLE_ADMIN' in user.roles ? 'Remove admin' : 'Make admin' }}
                                </button>
                            </form>
                            {% else %}
                            <span class="text-muted-foreground text-xs">You</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
                </div>
            </twig:Card:Content>
        </twig:Card>

    </div>
</div>
{% endblock %}
