# Copy this file to .env.prod on the server and fill in the values.
# docker compose --env-file .env.prod -f compose.prod.yaml up -d

# ── Symfony ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
APP_SECRET=replace_with_random_32_byte_hex

# ── Azure AD (OAuth2) ─────────────────────────────────────────────────────────
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# ── Optional ─────────────────────────────────────────────────────────────────
# Host port that nginx listens on (NPM should proxy to this). This is a fallback setting, the actual port is defaulted to 80 by the docker compose file and  NPM proxy references container by name rather than IP:port. If you change this, also change the nginx config in compose.prod.yaml.
HTTP_PORT=8080
