# Copy this file to .env on the server and fill in the values.
# Deploy: docker compose up -d --build --no-cache
# Restart: docker compose down && docker compose up -d

# App version, used in the footer and other places. Update this when releasing a new version.
APP_VERSION=0.6.2
APP_ENV=prod

###> symfony/framework-bundle ###
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://ledger.valuegroup.vg
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:////var/www/html/var/data.db"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=sync://
###< symfony/messenger ###

# ── Secrets (fill these in) ───────────────────────────────────────────────────
# Generate APP_SECRET with: openssl rand -hex 32
APP_SECRET=replace_with_random_32_byte_hex

###> AZURE OIDC ###
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
###< AZURE OIDC ###

# ── Optional ─────────────────────────────────────────────────────────────────
# Host port that nginx listens on (NPM should proxy to this).
# HTTP_PORT=8080
